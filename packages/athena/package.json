{
	"name": "athena",
	"version": "2.5.2-99",
	"license": "Apache-2.0",
	"scripts": {
		"start": "node server_watcher.js",
		"audit": "better-npm-audit audit --production",
		"lint": "./node_modules/.bin/eslint --no-eslintrc -c ./.eslintrc.json .",
		"detect-secrets": "detect-secrets-hook --baseline .secrets.baseline -v",
		"detect-secrets-create": "detect-secrets scan --update .secrets.baseline",
		"test": "npm run build:stitch && npx nyc --reporter=html --reporter=text --report-dir=./coverage mocha --timeout 6000 --exit 'test/test-suites/*/*.test.js'",
		"test:local": "npx nyc --reporter=html --reporter=text --report-dir=./coverage mocha --timeout 6000 --exit 'test/test-suites/*/*.test.js'",
		"test:simple": "npx nyc --reporter=html --reporter=text --report-dir=./coverage mocha --timeout 6000 --exit 'test/test-suites/*/*.test.js'",
		"test:all": "npm run build:stitch && npx nyc --reporter=html --reporter=text --report-dir=./coverage mocha --exit 'test/test-suites/external/*/*.test.js' 'test/test-suites/*/*.test.js' --reporter tap-file",
		"test:server": "npm run build:stitch && mocha --exit 'test/test-suites/*/*.test.js'",
		"test:external": "npm run build:stitch && npx nyc --reporter=html --reporter=text --report-dir=./coverage mocha --exit 'test/test-suites/external/*/*.test.js' --reporter tap-file",
		"dev:athena": "npm run build:stitch && npm run build:apollo && npm run start",
		"dev:apollo": "npm run build:stitch && npm run start",
		"build:apollo": "npm run --prefix ../apollo build",
		"build:stitch": "npm run --prefix ../stitch build_all",
		"validate:openapi": "swagger-cli --version && swagger-cli validate ./json_docs/json_validation/ibp_openapi_v3.yaml",
		"validate:openapi:cloud": "lint-openapi -s -c ./test/openapi/.validaterc.json -r ./test/openapi/.spectral.yaml ./json_docs/json_validation/ibp_openapi_v3.yaml",
		"validate:openapi:self": "node ./test/openapi/init_examples.js && node ./test/openapi/same_same.js && node ./test/openapi/unused.js && node ./test/openapi/response_inspection.js"
	},
	"repository": {
		"type": "git",
		"url": "https://github.ibm.com/IBM-Blockchain/athena.git"
	},
	"dependencies": {
		"async": "^3.2.5",
		"axios": "^1.12.0",
		"bn.js": "^5.2.3",
		"body-parser": "^1.18.3",
		"chokidar": "3.0.*",
		"compression": "^1.8.1",
		"cors": "2.8.*",
		"elliptic": "^6.6.1",
		"express": "^4.22.1",
		"express-rate-limit": "3.4.*",
		"express-session": "^1.18.1",
		"http-proxy": "1.18.*",
		"js-yaml": "^4.1.1",
		"jsrsasign": "^11.0.0",
		"node-cache": "5.1.*",
		"owasp-password-strength-test": "^1.3.0",
		"passport": "^0.6.0",
		"passport-idaas-openidconnect": "2.0.*",
		"passport-ldapauth": "3.0.*",
		"passport-oauth": "1.0.*",
		"protobufjs": "^7.2.5",
		"selfsigned": "^4.0.0",
		"uuid": "3.3.*",
		"winston": "2.4.*",
		"ws": "7.5.*",
		"zlib": "^1.0.5"
	},
	"devDependencies": {
		"chai": "^4.1.2",
		"chai-http": "^4.2.0",
		"eslint": "^8.8.0",
		"mocha": "^11.0.0",
		"node-mocks-http": "^1.7.3",
		"nyc": "^15.1.0",
		"sinon": "^6.1.5",
		"tap-file": "0.0.2"
	},
	"overrides": {
		"winston": {
			"async": "3.2.3"
		},
		"tough-cookie": "4.1.3",
		"form-data": "^4.0.4",
		"qs": "^6.14.1",
		"passport-idaas-openidconnect": {
			"jws": "3.2.3"
		},
		"elliptic": {
			"bn.js": "^5.2.3"
		}
	}
}
